# ---------------------------------------------------------------------------
# Copy to `.env` for local development:  cp .env.example .env
# NEVER commit a real .env file. Generate secrets, don't reuse these samples.
# ---------------------------------------------------------------------------

# --- Database ---------------------------------------------------------------
# Matches the credentials in docker-compose.yml for local dev.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/app?sslmode=disable"

# --- File storage (S3-compatible — MinIO by default) ------------------------
# Matches the `minio` service in docker-compose.yml for local dev — start it
# with `pnpm docker:minio`. MinIO stays internal-only in production (see
# docker-compose.prod.yml); the app is the only public gateway to it.
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_BUCKET="app-files"
# S3_REGION="us-east-1"

# Upload limits (optional — shown defaults). Comma-separated MIME allow-list.
# UPLOAD_MAX_SIZE_MB="10"
# MAX_STORAGE_PER_USER_MB="500"
# UPLOAD_ALLOWED_MIME_TYPES="image/png,image/jpeg,image/webp,image/gif,application/pdf"

# --- Auth.js (NextAuth v5) --------------------------------------------------
# Generate a strong secret:  openssl rand -base64 33   (or: npx auth secret)
AUTH_SECRET="replace-me-with-a-long-random-string"

# Canonical URL of the app. Required in production; optional locally.
# AUTH_URL="http://localhost:3000"

# Trust the host header (needed behind proxies / in Docker). Keep true in prod
# only when you terminate TLS at a trusted proxy.
AUTH_TRUST_HOST="true"

# OAuth providers (optional). Each is enabled only when BOTH its id and secret
# are set; leave unset for credentials-only auth. Callback URLs to register:
#   GitHub → {APP_URL}/api/auth/callback/github
#   Google → {APP_URL}/api/auth/callback/google
# AUTH_GITHUB_ID=""
# AUTH_GITHUB_SECRET=""
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# Public origin of this deployment. Used for OpenGraph/Twitter share-card image
# URLs (metadataBase) and the robots/sitemap routes. Optional locally (defaults
# to http://localhost:3000); set to the real domain per fork for correct cards.
# APP_URL="https://example.com"

# Require users to verify their email before admin actions are allowed (a soft
# gate — a banner + blocked admin mutations, not a full lockout). Only takes
# effect when email is enabled. Off by default.
# REQUIRE_EMAIL_VERIFICATION="false"

# --- Runtime ----------------------------------------------------------------
NODE_ENV="development"

# Log verbosity: debug | info | warn | error (defaults to debug / info in prod).
# LOG_LEVEL="info"

# Set to "true" to disable the in-memory auth rate limiter (e.g. some test runs).
# RATE_LIMIT_DISABLED="false"

# --- Email (optional, OFF by default) ---------------------------------------
# All email features (e.g. invite delivery) are disabled unless EMAIL_ENABLED
# is "true" AND an SMTP provider is configured below. If you set EMAIL_ENABLED
# without EMAIL_FROM + SMTP_HOST + SMTP_PORT, the app fails fast at boot.
# SMTP is provider-agnostic — Resend, SendGrid, Mailgun, SES, Postmark and Gmail
# all expose SMTP credentials.
# EMAIL_ENABLED="false"
# EMAIL_FROM="no-reply@example.com"
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"                # 587 (STARTTLS) or 465 (implicit TLS)
# SMTP_USER=""
# SMTP_PASSWORD=""
# SMTP_SECURE="false"            # force implicit TLS; auto-true when port is 465

# --- Cloudflare Tunnel deployment (optional) --------------------------------
# See docs/deployment.md. Runtime only needs the tunnel token; provisioning
# vars are only used by Terraform (`make tunnel-provision`).

# Runtime — the cloudflared daemon's run token (from `make tunnel-provision`).
# CLOUDFLARE_TUNNEL_TOKEN=""
# Public URL of the app behind the named tunnel (required for tunnel mode).
# AUTH_URL="https://app.example.com"

# Provisioning-only (Terraform) — scoped token: Account>Tunnel:Edit, Zone>DNS:Edit.
# Prefer infra/cloudflare/terraform.tfvars over env for these.
# CLOUDFLARE_API_TOKEN=""
# CLOUDFLARE_ACCOUNT_ID=""
# CLOUDFLARE_ZONE_ID=""
# TUNNEL_HOSTNAME="app.example.com"
