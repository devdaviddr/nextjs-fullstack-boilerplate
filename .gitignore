.turbo
*.tsbuildinfo

# terraform (state holds secrets; lockfile IS committed)
**/.terraform/*
*.tfstate
*.tfstate.*
crash.log
*.tfvars
!*.tfvars.example

# graphify generated knowledge graph (regenerated by the post-commit hook)
graphify-out/
