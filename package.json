{
  "name": "nextjs-fullstack-boilerplate",
  "version": "0.13.6",
  "private": true,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.9.0"
  },
  "packageManager": "pnpm@11.5.1",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,mjs,cjs}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,mjs,cjs}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts",
    "gen:icons": "node scripts/generate-icons.mjs",
    "gen:og": "node scripts/generate-og-image.mjs",
    "docker:db": "docker compose up -d db",
    "docker:minio": "docker compose up -d minio minio-init",
    "docker:mail": "docker compose up -d mailpit",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "1.11.2",
    "@aws-sdk/client-s3": "^3.1085.0",
    "@hookform/resolvers": "5.4.0",
    "@node-rs/argon2": "2.0.2",
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-label": "2.1.11",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-slot": "1.3.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.2",
    "lucide-react": "1.24.0",
    "next": "16.2.10",
    "next-auth": "5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "nodemailer": "^9.0.3",
    "postgres": "3.4.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.81.0",
    "server-only": "0.0.1",
    "tailwind-merge": "3.6.0",
    "web-push": "^3.6.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "22.20.1",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "dotenv": "17.4.2",
    "drizzle-kit": "0.31.10",
    "eslint": "9.18.0",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "10.1.8",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "16.2.4",
    "prettier": "3.9.5",
    "prettier-plugin-tailwindcss": "0.8.0",
    "sharp": "0.34.5",
    "tailwindcss": "4.3.2",
    "tsx": "4.20.3",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.10"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,json,mjs,cjs,css}": [
      "prettier --write"
    ]
  }
}
